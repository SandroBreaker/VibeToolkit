<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SENTINEL HUD"
        Height="760"
        Width="1220"
        MinHeight="760"
        MinWidth="1220"
        WindowStartupLocation="CenterScreen"
        Background="#070C12"
        Foreground="#E6EDF3"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#070C12"/>
        <SolidColorBrush x:Key="RootBorderBrush" Color="#22364A"/>
        <SolidColorBrush x:Key="HeaderBrush" Color="#0B131D"/>
        <SolidColorBrush x:Key="HeaderBorderBrush" Color="#2A4158"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#0B121A"/>
        <SolidColorBrush x:Key="PanelBrushAlt" Color="#0A1017"/>
        <SolidColorBrush x:Key="PanelOverlayBrush" Color="#132131"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#273A4F"/>
        <SolidColorBrush x:Key="PanelBorderStrongBrush" Color="#3A5875"/>
        <SolidColorBrush x:Key="InputBrush" Color="#0A1118"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#334A63"/>
        <SolidColorBrush x:Key="TextBrush" Color="#E7EEF7"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9AAABE"/>
        <SolidColorBrush x:Key="SoftTextBrush" Color="#7F93A7"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2F7DCC"/>
        <SolidColorBrush x:Key="AccentBrushSoft" Color="#0E243A"/>
        <SolidColorBrush x:Key="AccentBorderBrush" Color="#4A94DE"/>
        <SolidColorBrush x:Key="SelectionBrush" Color="#245E94"/>
        <SolidColorBrush x:Key="NeutralButtonBrush" Color="#101922"/>
        <SolidColorBrush x:Key="NeutralButtonHoverBrush" Color="#162434"/>

        <LinearGradientBrush x:Key="ChromeBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0B121B" Offset="0"/>
            <GradientStop Color="#111B28" Offset="0.55"/>
            <GradientStop Color="#0A1118" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PanelGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#101824" Offset="0"/>
            <GradientStop Color="#0B121A" Offset="0.58"/>
            <GradientStop Color="#091018" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="HeaderGradientBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#0D1520" Offset="0"/>
            <GradientStop Color="#141F2D" Offset="0.48"/>
            <GradientStop Color="#0D1520" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="RunButtonGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#2A7ED0" Offset="0"/>
            <GradientStop Color="#1E5F9C" Offset="1"/>
        </LinearGradientBrush>

        <DropShadowEffect x:Key="PanelShadow"
                          BlurRadius="18"
                          ShadowDepth="0"
                          Color="#010408"
                          Opacity="0.34"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="{StaticResource PanelGradientBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect" Value="{StaticResource PanelShadow}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SectionHintStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SoftTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DCE6F2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource SelectionBrush}"/>
            <Setter Property="SelectionOpacity" Value="0.45"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="DarkComboToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Grid.Column="0"
                                                  Margin="10,0,8,0"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>

                                <Border Grid.Column="1"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1,0,0,0"
                                        Background="#101A26">
                                    <Path Width="10"
                                          Height="6"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Data="M 0 0 L 5 6 L 10 0 Z"
                                          Fill="{StaticResource SoftTextBrush}"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource AccentBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource AccentBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#FFFFFF"/>
                        <Setter Property="Background" Value="{StaticResource PanelBrushAlt}"/>
                        <Setter Property="Padding" Value="10,7"/>
                        <Setter Property="SnapsToDevicePixels" Value="True"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Left"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#142334"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentBrushSoft}"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.55"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <ToggleButton x:Name="ToggleButton"
                                          Style="{StaticResource DarkComboToggleButtonStyle}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  TextElement.Foreground="#FFFFFF"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                            </ToggleButton>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border x:Name="PopupBorder"
                                        Margin="0,4,0,0"
                                        Background="{StaticResource PanelBrushAlt}"
                                        BorderBrush="{StaticResource InputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PopupBorder" Property="MinHeight" Value="36"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{StaticResource AccentBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource NeutralButtonBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource RunButtonGradient}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBorderBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="24,10"/>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="#101721"/>
        </Style>

        <Style TargetType="TreeView">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style x:Key="LogListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="#071019"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderStrongBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
        </Style>

        <Style x:Key="LogListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="16"
            Padding="12"
            Background="{StaticResource ChromeBackgroundBrush}"
            BorderBrush="{StaticResource RootBorderBrush}"
            BorderThickness="1"
            CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource PanelCardStyle}"
                    Background="{StaticResource HeaderGradientBrush}"
                    BorderBrush="{StaticResource HeaderBorderBrush}"
                    Padding="12,10"
                    Margin="0,0,0,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="230"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE80F;"
                                       FontSize="18"
                                       Foreground="{StaticResource AccentBorderBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE7F8;"
                                       FontSize="17"
                                       Margin="18,0,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock x:Name="txtHeader"
                                   Grid.Column="1"
                                   Text="SENTINEL HUD — WPF"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Border Padding="12,5"
                                    Margin="0,0,10,0"
                                    CornerRadius="999"
                                    Background="{StaticResource AccentBrushSoft}"
                                    BorderBrush="{StaticResource AccentBorderBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="Pipeline"
                                           Foreground="#91C7FF"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                            </Border>

                            <Border x:Name="brdRunState"
                                    Padding="12,5"
                                    CornerRadius="999"
                                    Background="#0E1721"
                                    BorderBrush="{StaticResource AccentBorderBrush}"
                                    BorderThickness="1">
                                <TextBlock x:Name="txtRunState"
                                           Text="Concluído"
                                           FontWeight="SemiBold"
                                           Foreground="#E8F2FC"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="txtSubHeader"
                               Grid.Row="1"
                               Margin="0,8,0,0"
                               Text="Painel operacional denso. Preparação à esquerda, execução à direita. Sem gordura decorativa."
                               HorizontalAlignment="Left"
                               Foreground="{StaticResource MutedTextBrush}"/>

                    <TextBlock x:Name="txtTargetPath"
                               Grid.Row="2"
                               Margin="0,8,0,0"
                               Text="Path: C:\dev\VibeToolkit"
                               FontFamily="Consolas"
                               FontSize="12"
                               Foreground="{StaticResource SoftTextBrush}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="372"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource PanelCardStyle}" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="Preparação da operação" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,2"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Modo de extração" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="cmbBundleMode" Height="28"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1">
                                    <TextBlock Text="Rota" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="cmbRouteMode" Height="28"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,6,8,0">
                                    <TextBlock Text="Provider" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="cmbProvider" Height="28"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,6,0,0">
                                    <TextBlock Text="Modo de prompt IA" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="cmbAIPromptMode" Height="28"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,6,0,0">
                                    <TextBlock Text="Executor alvo" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="txtExecutorTarget" Height="28"/>
                                </StackPanel>

                                <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,6,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <CheckBox x:Name="chkSendToAI" Grid.Row="0" Content="Gerar prompt final com IA" Margin="0,0,0,4"/>
                                    <CheckBox x:Name="chkDeterministicDirector" Grid.Row="1" Content="Gerar meta-prompt determinístico local" Margin="0,0,0,6"/>
                                    <Border Grid.Row="2"
                                            Padding="6,4"
                                            Background="{StaticResource InputBrush}"
                                            BorderBrush="{StaticResource InputBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="2">
                                        <TextBlock Text="No Sniper: Espaço marca, ←/→ expande ou recolhe."
                                                   Foreground="{StaticResource SoftTextBrush}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource PanelCardStyle}">
                        <DockPanel LastChildFill="True">
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Seleção Sniper" Style="{StaticResource SectionTitleStyle}"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        x:Name="btnSelectAll"
                                        Content="Marcar tudo"
                                        Margin="12,0,8,0"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource GhostButtonStyle}"/>

                                <Button Grid.Column="2"
                                        x:Name="btnSelectNone"
                                        Content="Limpar"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource GhostButtonStyle}"/>
                            </Grid>

                            <Border DockPanel.Dock="Top"
                                    Margin="0,0,0,10"
                                    Padding="10,7"
                                    Background="{StaticResource InputBrush}"
                                    BorderBrush="{StaticResource InputBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2">
                                <TextBlock x:Name="txtSelectionSummary"
                                           Foreground="{StaticResource SoftTextBrush}"/>
                            </Border>

                            <TreeView x:Name="trvFiles"
                                      ScrollViewer.CanContentScroll="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"/>
                        </DockPanel>
                    </Border>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource PanelCardStyle}"
                            BorderBrush="{StaticResource PanelBorderStrongBrush}">
                        <DockPanel LastChildFill="True">
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Log operacional" Style="{StaticResource SectionTitleStyle}" FontSize="18"/>
                                    <TextBlock Text="Painel dominante da tela. Aqui vivem a execução, as falhas e a saída real — finalmente no lugar certo."
                                               Style="{StaticResource SectionHintStyle}"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        x:Name="btnCopyLogs"
                                        Content="Copiar logs"
                                        Margin="12,0,8,0"
                                        Style="{StaticResource GhostButtonStyle}"
                                        VerticalAlignment="Top"/>

                                <Border Grid.Column="2"
                                        Padding="10,5"
                                        CornerRadius="999"
                                        Background="#081520"
                                        BorderBrush="{StaticResource PanelBorderStrongBrush}"
                                        BorderThickness="1"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="execução ao vivo"
                                               Foreground="#7CBFFF"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </Grid>

                            <ListBox x:Name="lstLog"
                                     Style="{StaticResource LogListStyle}"
                                     ItemContainerStyle="{StaticResource LogListItemStyle}"
                                     FontFamily="Consolas"
                                     FontSize="14"/>
                        </DockPanel>
                    </Border>

                    <TextBox x:Name="txtExecutionSummary"
                             Visibility="Collapsed"
                             Width="0" Height="0" Margin="-9999" />

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="btnRun"
                                Content="Executar"
                                Margin="0,0,10,0"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button x:Name="btnClose"
                                Content="Fechar"
                                Padding="22,10"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <Border Grid.Row="2"
                    Margin="0,14,0,0"
                    Background="#091018"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="10,8">
                <TextBlock x:Name="txtFooterStatus"
                           Text="Execução concluída sem explodir. HUD mantida aberta."
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </Border>
</Window>
