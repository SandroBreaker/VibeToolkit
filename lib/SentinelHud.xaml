<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SENTINEL HUD"
        Height="900"
        Width="1480"
        MinHeight="760"
        MinWidth="1220"
        WindowStartupLocation="CenterScreen"
        Background="#0B1118"
        Foreground="#E6EDF3"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#0B1118"/>
        <SolidColorBrush x:Key="HeaderBrush" Color="#0D141D"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#101822"/>
        <SolidColorBrush x:Key="PanelBrushAlt" Color="#0D141C"/>
        <SolidColorBrush x:Key="PanelBrushSubtle" Color="#0A121A"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#203142"/>
        <SolidColorBrush x:Key="PanelBorderStrongBrush" Color="#2D4C6B"/>
        <SolidColorBrush x:Key="InputBrush" Color="#091018"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#27405A"/>
        <SolidColorBrush x:Key="TextBrush" Color="#E6EDF3"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9AAEC3"/>
        <SolidColorBrush x:Key="SoftTextBrush" Color="#778CA2"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#1C6CB3"/>
        <SolidColorBrush x:Key="AccentBrushSoft" Color="#103150"/>
        <SolidColorBrush x:Key="AccentBorderBrush" Color="#2F84D0"/>
        <SolidColorBrush x:Key="SelectionBrush" Color="#1C6CB3"/>
        <SolidColorBrush x:Key="RunButtonBrush" Color="#1A5E99"/>
        <SolidColorBrush x:Key="RunButtonHoverBrush" Color="#2478C1"/>
        <SolidColorBrush x:Key="NeutralButtonBrush" Color="#13202D"/>
        <SolidColorBrush x:Key="NeutralButtonHoverBrush" Color="#182838"/>

        <LinearGradientBrush x:Key="RunButtonGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1F73BB" Offset="0"/>
            <GradientStop Color="#164E7D" Offset="1"/>
        </LinearGradientBrush>

        <DropShadowEffect x:Key="PanelShadow"
                          BlurRadius="16"
                          ShadowDepth="0"
                          Color="#010408"
                          Opacity="0.28"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Effect" Value="{StaticResource PanelShadow}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="PanelSubtleStyle" TargetType="Border" BasedOn="{StaticResource PanelCardStyle}">
            <Setter Property="Background" Value="{StaticResource PanelBrushAlt}"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SectionHintStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SoftTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DCE6F2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource SelectionBrush}"/>
            <Setter Property="SelectionOpacity" Value="0.45"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="DarkComboToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Grid.Column="0"
                                                  Margin="10,0,8,0"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>

                                <Border Grid.Column="1"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1,0,0,0"
                                        Background="#0B1722">
                                    <Path Width="10"
                                          Height="6"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Data="M 0 0 L 5 6 L 10 0 Z"
                                          Fill="{StaticResource SoftTextBrush}"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource AccentBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource AccentBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#FFFFFF"/>
                        <Setter Property="Background" Value="{StaticResource PanelBrushAlt}"/>
                        <Setter Property="Padding" Value="10,7"/>
                        <Setter Property="SnapsToDevicePixels" Value="True"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Left"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#122235"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentBrushSoft}"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.55"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <ToggleButton x:Name="ToggleButton"
                                          Style="{StaticResource DarkComboToggleButtonStyle}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ContentPresenter Margin="0"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  TextElement.Foreground="#FFFFFF"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                            </ToggleButton>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border x:Name="PopupBorder"
                                        Margin="0,4,0,0"
                                        Background="{StaticResource PanelBrushAlt}"
                                        BorderBrush="{StaticResource InputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer Margin="0"
                                                  SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PopupBorder" Property="MinHeight" Value="36"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{StaticResource AccentBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource NeutralButtonBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource RunButtonGradient}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBorderBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="{StaticResource NeutralButtonBrush}"/>
        </Style>

        <Style TargetType="TreeView">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="Background" Value="#03080E"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PanelCardStyle}"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource PanelBorderStrongBrush}"
                Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="txtHeader"
                               Text="SENTINEL HUD — WPF"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtSubHeader"
                               Margin="0,2,0,0"
                               Text="Preparar, disparar e inspecionar. O foco fica na operação, não no teatro visual." 
                               Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock x:Name="txtTargetPath"
                               Margin="0,7,0,0"
                               Text="Path:"
                               FontFamily="Consolas"
                               FontSize="12"
                               Foreground="{StaticResource SoftTextBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Border Padding="10,5"
                            CornerRadius="999"
                            Background="{StaticResource AccentBrushSoft}"
                            BorderBrush="{StaticResource AccentBorderBrush}"
                            BorderThickness="1"
                            Margin="0,0,10,0">
                        <TextBlock Text="Pipeline"
                                   Foreground="#8FC6FF"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <Border x:Name="brdRunState"
                            Padding="12,5"
                            CornerRadius="999"
                            Background="#0B1825"
                            BorderBrush="{StaticResource AccentBorderBrush}"
                            BorderThickness="1">
                        <TextBlock x:Name="txtRunState"
                                   Text="Pronto"
                                   FontWeight="SemiBold"
                                   Foreground="#8FC6FF"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.78*"/>
                <ColumnDefinition Width="1.52*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,14,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource PanelCardStyle}"
                        Margin="0,0,0,14">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                            <TextBlock Text="Preparação da operação" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Configuração enxuta: decide, parametriza e parte para a execução. Sem formulário querendo roubar a cena." Style="{StaticResource SectionHintStyle}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Modo de extração" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox x:Name="cmbBundleMode" Height="36"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1">
                                <TextBlock Text="Rota" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox x:Name="cmbRouteMode" Height="36"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,12,10,0">
                                <TextBlock Text="Provider" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox x:Name="cmbProvider" Height="36"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,12,0,0">
                                <TextBlock Text="Modo de prompt IA" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox x:Name="cmbAIPromptMode" Height="36"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,12,0,0">
                                <TextBlock Text="Executor alvo" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="txtExecutorTarget" Height="36"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,12,0,0">
                                <CheckBox x:Name="chkSendToAI" Content="Gerar prompt final com IA"/>
                                <CheckBox x:Name="chkDeterministicDirector" Content="Gerar meta-prompt determinístico local" Margin="0"/>
                                <Border Margin="0,4,0,0"
                                        Padding="10,8"
                                        CornerRadius="8"
                                        Background="{StaticResource PanelBrushSubtle}"
                                        BorderBrush="{StaticResource InputBorderBrush}"
                                        BorderThickness="1">
                                    <TextBlock Text="No Sniper: Espaço marca, ←/→ expande ou recolhe e clique na pasta propaga para os filhos."
                                               Foreground="{StaticResource SoftTextBrush}"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource PanelCardStyle}">
                    <DockPanel LastChildFill="True">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Seleção Sniper" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="Seleção manual com leitura limpa. Sem panelinha espremida e sem caça ao checkbox."
                                           Style="{StaticResource SectionHintStyle}"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    x:Name="btnSelectAll"
                                    Content="Marcar tudo"
                                    Margin="12,0,8,0"
                                    Style="{StaticResource GhostButtonStyle}"/>

                            <Button Grid.Column="2"
                                    x:Name="btnSelectNone"
                                    Content="Limpar"
                                    Style="{StaticResource GhostButtonStyle}"/>
                        </Grid>

                        <Border DockPanel.Dock="Top"
                                Margin="0,0,0,10"
                                Padding="10,7"
                                CornerRadius="8"
                                Background="{StaticResource PanelBrushSubtle}"
                                BorderBrush="{StaticResource InputBorderBrush}"
                                BorderThickness="1">
                            <TextBlock x:Name="txtSelectionSummary" Foreground="{StaticResource SoftTextBrush}"/>
                        </Border>

                        <TreeView x:Name="trvFiles"
                                  ScrollViewer.CanContentScroll="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"/>
                    </DockPanel>
                </Border>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.62*"/>
                    <RowDefinition Height="0.48*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource PanelCardStyle}"
                        Background="#0C131A"
                        BorderBrush="{StaticResource PanelBorderStrongBrush}"
                        Padding="14"
                        Margin="0,0,0,14">
                    <DockPanel LastChildFill="True">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Log operacional" Style="{StaticResource SectionTitleStyle}" FontSize="18"/>
                                <TextBlock Text="Painel dominante da tela. Aqui vivem a execução, as falhas e a saída real — finalmente no lugar certo." Style="{StaticResource SectionHintStyle}" TextWrapping="Wrap"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    x:Name="btnCopyLogs"
                                    Content="Copiar logs"
                                    Margin="12,0,8,0"
                                    Style="{StaticResource GhostButtonStyle}"
                                    VerticalAlignment="Top"/>

                            <Border Grid.Column="2"
                                    Padding="10,5"
                                    CornerRadius="999"
                                    Background="#081520"
                                    BorderBrush="{StaticResource PanelBorderStrongBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Top">
                                <TextBlock Text="execução ao vivo"
                                           Foreground="#7CBFFF"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </Grid>

                        <ListBox x:Name="lstLog"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"/>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource PanelCardStyle}">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock Text="Resumo da última execução" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Fechamento rápido com status, parâmetros e contexto do disparo. O que interessa, sem textão ornamental." Style="{StaticResource SectionHintStyle}"/>
                        </StackPanel>

                        <TextBox x:Name="txtExecutionSummary"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 FontFamily="Consolas"
                                 FontSize="13"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource PanelCardStyle}"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="txtFooterStatus"
                           Text="Aguardando execução."
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="14,0,0,0">
                    <Button x:Name="btnRun"
                            Content="Executar"
                            Padding="22,9"
                            Margin="0,0,8,0"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                    <Button x:Name="btnClose"
                            Content="Fechar"
                            Padding="18,9"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>